{
  "author": "maxbirkner",
  "dependencies": {
    "@actions/artifact": "2.3.2",
    "@actions/core": "1.11.1",
    "@actions/github": "6.0.1",
    "@octokit/auth-app": "^8.0.2",
    "@resvg/resvg-wasm": "^2.6.2",
    "d3": "^7.8.5",
    "d3-hierarchy": "^3.1.2",
    "dejavu-fonts-ttf": "2.37.3",
    "jsdom": "29.1.1",
    "picomatch": "^4.0.3"
  },
  "description": "GitHub Action that analyzes code coverage for files changed in a pull request and generates a visual treemap",
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/d3": "^7.4.3",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "28.0.3",
    "@types/node": "25.9.3",
    "@types/picomatch": "^4.0.2",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "@vercel/ncc": "0.44.0",
    "eslint": "9.39.4",
    "jest": "^30.0.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.1"
  },
  "keywords": [
    "github-action",
    "coverage",
    "lcov",
    "treemap",
    "testing"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "name": "coveragemap-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxbirkner/coveragemap.git"
  },
  "scripts": {
    "build": "tsc",
    "format": "prettier --write src/**/*.ts",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "version": "1.0.0"
}
